{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GlobalConfig",
  "type": "object",
  "required": ["version", "storageDir", "defaultStorage", "enforcement", "autoCommit", "claimTtlHours", "trackManifest", "projects"],
  "properties": {
    "version": { "type": "integer" },
    "storageDir": { "type": "string" },
    "defaultStorage": { "type": "string", "enum": ["global", "local"] },
    "enforcement": { "type": "string", "enum": ["warn", "block", "off"] },
    "autoCommit": { "type": "boolean" },
    "claimTtlHours": { "type": "number" },
    "trackManifest": { "type": "boolean" },
    "tasksDirName": { "type": "string", "default": "agent-tasks", "description": "Per-project subdirectory name for task files" },
    "projects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["prefix", "path", "storage"],
        "properties": {
          "prefix": { "type": "string" },
          "name": { "type": "string", "maxLength": 80, "description": "Optional friendly display name; falls back to the prefix when unset." },
          "path": { "type": "string", "description": "Absolute path to the project root. For the GEN global project, set to the user home subdirectory (e.g. ~/.mcp-tasks)." },
          "storage": { "type": "string", "enum": ["global", "local"] }
        }
      }
    },
    "areas": {
      "type": "object",
      "description": "Maps project prefixes to their PARA area. Used for area-resolution fallback when a task has no explicit area.",
      "additionalProperties": { "type": "string", "enum": ["client", "personal", "outsource", "internal"] }
    }
  }
}
