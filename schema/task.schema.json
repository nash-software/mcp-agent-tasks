{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TaskFrontmatter",
  "type": "object",
  "required": ["schema_version", "id", "title", "type", "status", "priority", "project", "why", "created", "updated", "last_activity"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "id": { "type": "string", "pattern": "^[A-Z]+-\\d+$" },
    "title": { "type": "string", "maxLength": 200 },
    "type": { "type": "string", "enum": ["feature", "bug", "chore", "spike", "refactor"] },
    "status": { "type": "string", "enum": ["todo", "in_progress", "done", "blocked", "archived"] },
    "priority": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
    "project": { "type": "string" },
    "tags": { "type": "array", "maxItems": 10, "items": { "type": "string", "maxLength": 50 } },
    "complexity": { "type": "integer", "minimum": 1, "maximum": 10 },
    "complexity_manual": { "type": "boolean" },
    "why": { "type": "string", "maxLength": 1000 },
    "created": { "type": "string" },
    "updated": { "type": "string" },
    "last_activity": { "type": "string" },
    "claimed_by": { "type": ["string", "null"] },
    "claimed_at": { "type": ["string", "null"] },
    "claim_ttl_hours": { "type": "number" },
    "parent": { "type": ["string", "null"] },
    "children": { "type": "array", "items": { "type": "string" } },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "subtasks": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": ["id", "title", "status"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "status": { "type": "string", "enum": ["todo", "in_progress", "done", "blocked"] }
        }
      }
    },
    "git": {
      "type": "object",
      "properties": {
        "branch": { "type": "string" },
        "commits": { "type": "array" },
        "pr": { "type": "object" }
      }
    },
    "transitions": { "type": "array" },
    "files": { "type": "array", "items": { "type": "string" } }
  }
}
